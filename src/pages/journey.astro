---
import Layout from "../layouts/Layout.astro";
import AppWrapper from "../components/AppWrapper.tsx";

const posts = await Astro.glob('../content/journey/*.md');

const journeyPosts = posts.map(post => {
    const slug = post.file.split('/').pop()?.split('.').shift() || '';
    return {
        slug,
        ...post.frontmatter
    };
});
---

<Layout>
    <AppWrapper client:load page="journey" journeyPosts={journeyPosts} />
</Layout>
