---
import Layout from "../../layouts/Layout.astro";
import AppWrapper from "../../components/AppWrapper.tsx";

export function getStaticPaths() {
    return [
        { params: { slug: "integration-payment-gateway-midtrans" } },
        { params: { slug: "why-astro-for-portfolio" } },
        { params: { slug: "building-real-world-projects" } },
    ];
}

const { slug } = Astro.params;
---

<Layout>
    <AppWrapper client:load page="blog_detail" blogSlug={slug} />
</Layout>
